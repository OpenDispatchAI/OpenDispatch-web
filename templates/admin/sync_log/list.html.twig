{% extends 'base.html.twig' %}

{% block title %}Sync Log — OpenDispatch Admin{% endblock %}

{% block body %}
<h1>Sync Log</h1>

<table>
    <thead>
        <tr>
            <th>Date</th>
            <th>Status</th>
            <th>Skills</th>
            <th>Commit</th>
            <th>Action</th>
            <th>Error</th>
        </tr>
    </thead>
    <tbody>
        {% for log in logs %}
        <tr>
            <td>{{ log.syncedAt|date('Y-m-d H:i:s') }}</td>
            <td>
                {% if log.status == 'success' %}
                    <span class="badge badge-success">Success</span>
                {% else %}
                    <span class="badge badge-danger">Failed</span>
                {% endif %}
            </td>
            <td>{{ log.skillCount }}</td>
            <td>
                {% if log.commitUrl %}
                    <a href="{{ log.commitUrl }}" target="_blank">{{ log.commitSha|slice(0, 7) }}</a>
                {% else %}
                    {{ log.commitSha|slice(0, 7) }}
                {% endif %}
            </td>
            <td>
                {% if log.actionRunUrl %}
                    <a href="{{ log.actionRunUrl }}" target="_blank">View</a>
                {% else %}
                    —
                {% endif %}
            </td>
            <td>{{ log.errorMessage ? log.errorMessage|slice(0, 100) : '—' }}</td>
        </tr>
        {% else %}
        <tr>
            <td colspan="6">No sync logs yet.</td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% endblock %}
